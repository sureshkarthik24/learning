from pyspark.sql import SparkSession
from pyspark.sql.window import Window
from pyspark.sql.functions import lag, col, when, sum, unix_timestamp

spark = SparkSession.builder.appName("Sessionizer").getOrCreate()

# 1. Define the Window (Partition by user, order by time)
window_spec = Window.partitionBy("user_id").orderBy("timestamp")

# 2. Get the previous timestamp
df_with_prev = df.withColumn("prev_ts", lag("timestamp").over(window_spec))

# 3. Calculate the gap and flag new sessions
# We convert to unix_timestamp to do math in seconds (1800s = 30m)
session_flag_df = df_with_prev.withColumn(
    "is_new_session", 
    when(
        (unix_timestamp(col("timestamp")) - unix_timestamp(col("prev_ts")) > 1800) | 
        (col("prev_ts").isNull()), 
        1
    ).otherwise(0)
)

# 4. Cumulative sum to create the Session ID
session_id_df = session_flag_df.withColumn(
    "session_id", 
    sum(col("is_new_session")).over(window_spec)
)

session_id_df.show()